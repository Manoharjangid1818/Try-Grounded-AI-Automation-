{
    "name": "grounded-ai-automation",
    "version": "1.0.0",
    "description": "Playwright UI test suite for the Grounded AI dashboard",
    "author": "Manohar Jangid",
    "license": "UNLICENSED",
    "type": "module",
    "scripts": {
        "prepare": "husky",
        "auth": "npx playwright test tests/auth.setup.spec.js",
        "test": "npx playwright test",
        "test:ui": "npx playwright test --ui",
        "test:list": "npx playwright test --list",
        "test:headed": "npx playwright test --headed",
        "test:smoke": "npx playwright test --grep @smoke",
        "test:regression": "npx playwright test --grep @regression",
        "test:bulk": "npx playwright test tests/bulkAudit.spec.js",
        "test:custom": "npx playwright test tests/customRules.spec.js",
        "test:model": "npx playwright test tests/modelIntelligence.spec.js",
        "test:quick": "npx playwright test tests/quickTests.spec.js",
        "test:monitor": "npx playwright test tests/regressionMonitor.spec.js",
        "test:response": "npx playwright test tests/responseAudit.spec.js",
        "test:conversation": "npx playwright test tests/conversationAnalysis.spec.js",
        "test:selected": "node scripts/run-selected.js",
        "test:files": "node scripts/run-files.js",
        "report": "npx playwright show-report",
        "lint": "eslint .",
        "format": "prettier . --write",
        "format:check": "prettier . --check"
    },
    "dependencies": {
        "@playwright/test": "^1.54.0",
        "dotenv": "^16.4.5"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "eslint": "^10.5.0",
        "globals": "^17.7.0",
        "husky": "^9.1.7",
        "prettier": "^3.8.4"
    }
}
